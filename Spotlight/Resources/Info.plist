<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>Looty</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIconName</key>
	<string>AppIcon</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>auth-callback</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>$(SPOTLIGHT_AUTH_REDIRECT_SCHEME)</string>
			</array>
		</dict>
	</array>
	<key>CFBundleShortVersionString</key>
	<string>1.0</string>
	<key>CFBundleVersion</key>
	<string>1</string>
	<key>LSSupportsOpeningDocumentsInPlace</key>
	<true/>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>NSCameraUsageDescription</key>
	<string>Looty needs camera access to scan Pokemon cards for identification and pricing.</string>
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsLocalNetworking</key>
		<true/>
	</dict>
	<key>NSLocalNetworkUsageDescription</key>
	<string>Looty needs local network access to connect to your Mac for card pricing and catalog matching.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>Looty needs photo library access to import card images for identification.</string>
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>Looty can save captured scan images to your photo library.</string>
	<key>SpotlightAPIBaseURL</key>
	<string>$(SPOTLIGHT_API_BASE_URL)</string>
	<key>SpotlightDeviceAPIBaseURL</key>
	<string>$(SPOTLIGHT_DEVICE_API_BASE_URL)</string>
	<key>SpotlightEnvironment</key>
	<string>$(SPOTLIGHT_ENVIRONMENT)</string>
	<key>SpotlightSupabaseURL</key>
	<string>$(SPOTLIGHT_SUPABASE_URL)</string>
	<key>SpotlightSupabaseAnonKey</key>
	<string>$(SPOTLIGHT_SUPABASE_ANON_KEY)</string>
	<key>SpotlightAuthRedirectURL</key>
	<string>$(SPOTLIGHT_AUTH_REDIRECT_URL)</string>
	<key>SpotlightScanArtifactUploadsEnabled</key>
	<string>$(SPOTLIGHT_SCAN_ARTIFACT_UPLOADS_ENABLED)</string>
	<key>UIApplicationSceneManifest</key>
	<dict>
		<key>UIApplicationSupportsMultipleScenes</key>
		<true/>
	</dict>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>
	<key>UILaunchScreen</key>
	<dict/>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>
	<key>UIFileSharingEnabled</key>
	<true/>
</dict>
</plist>
