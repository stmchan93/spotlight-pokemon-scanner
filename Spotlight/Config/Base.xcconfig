// Shared app environment settings.
// Use the per-configuration xcconfig files to choose the backend environment.

SPOTLIGHT_ENVIRONMENT =
SPOTLIGHT_API_BASE_URL =
SPOTLIGHT_DEVICE_API_BASE_URL =
SPOTLIGHT_SCAN_ARTIFACT_UPLOADS_ENABLED =
SPOTLIGHT_SUPABASE_URL =
SPOTLIGHT_SUPABASE_ANON_KEY =
SPOTLIGHT_AUTH_REDIRECT_SCHEME = $(PRODUCT_BUNDLE_IDENTIFIER)
SPOTLIGHT_AUTH_REDIRECT_HOST = login-callback
SPOTLIGHT_AUTH_REDIRECT_URL = $(SPOTLIGHT_AUTH_REDIRECT_SCHEME):/$()/$(SPOTLIGHT_AUTH_REDIRECT_HOST)
