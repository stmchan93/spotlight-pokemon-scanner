#include "Base.xcconfig"

// Local development defaults.
SPOTLIGHT_LOCAL_SIMULATOR_API_BASE_URL = http:/$()/127.0.0.1:8788/
SPOTLIGHT_LOCAL_DEVICE_API_BASE_URL =

#include? "LocalOverrides.xcconfig"

SPOTLIGHT_ENVIRONMENT = local
SPOTLIGHT_API_BASE_URL = $(SPOTLIGHT_LOCAL_SIMULATOR_API_BASE_URL)
SPOTLIGHT_DEVICE_API_BASE_URL = $(SPOTLIGHT_LOCAL_DEVICE_API_BASE_URL)
SPOTLIGHT_SCAN_ARTIFACT_UPLOADS_ENABLED = NO
