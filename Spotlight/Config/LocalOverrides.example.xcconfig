// Copy this file to LocalOverrides.xcconfig and edit the values for your machine.
// LocalOverrides.xcconfig is gitignored and is the app-side equivalent of a local .env file.

// Required for physical-device debug runs against your Mac.
// Prefer your Mac's Bonjour hostname over a raw LAN IP so this keeps working across Wi-Fi changes.
// Example: if `scutil --get LocalHostName` prints `Stephens-MacBook-Pro`, use:
SPOTLIGHT_LOCAL_DEVICE_API_BASE_URL = http:/$()/Stephens-MacBook-Pro.local:8788/

// Optional. For now staging and production are the same backend.
SPOTLIGHT_STAGING_API_BASE_URL = https:/$()/looty.34.59.188.129.sslip.io/

// Optional. Override production without editing Release.xcconfig.
SPOTLIGHT_PRODUCTION_API_BASE_URL = https:/$()/looty.34.59.188.129.sslip.io/

// Optional. Override scan artifact uploads for local testing.
// Debug defaults to NO. Staging/Release default to YES.
SPOTLIGHT_SCAN_ARTIFACT_UPLOADS_ENABLED = NO

// Required for Supabase Auth.
SPOTLIGHT_SUPABASE_URL = https:/$()/your-project-ref.supabase.co
SPOTLIGHT_SUPABASE_ANON_KEY = your-supabase-anon-key

// Optional. Override the auth callback host if you need a different deep-link target.
SPOTLIGHT_AUTH_REDIRECT_HOST = login-callback
