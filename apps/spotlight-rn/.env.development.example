# Public runtime config bundled into the Expo app.
# Development should target your local backend by default.
# For physical-device testing, the phone helper script overrides this to your Mac LAN IP.
EXPO_PUBLIC_SPOTLIGHT_API_BASE_URL=http://127.0.0.1:8788
EXPO_PUBLIC_SPOTLIGHT_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SPOTLIGHT_SUPABASE_ANON_KEY=your-supabase-anon-or-publishable-key
EXPO_PUBLIC_SPOTLIGHT_AUTH_REDIRECT_URL=spotlight://login-callback
EXPO_PUBLIC_SPOTLIGHT_AUTH_SCHEME=spotlight

# Native identifiers used by app.config.js.
SPOTLIGHT_IOS_BUNDLE_IDENTIFIER=com.yourcompany.spotlight
SPOTLIGHT_ANDROID_PACKAGE=com.yourcompany.spotlight
SPOTLIGHT_EXPO_OWNER=your-expo-account

# Recommended once the Expo project exists.
SPOTLIGHT_EAS_PROJECT_ID=00000000-0000-0000-0000-000000000000

# Optional if you want a scheme different from the default "spotlight".
SPOTLIGHT_APP_SCHEME=spotlight
