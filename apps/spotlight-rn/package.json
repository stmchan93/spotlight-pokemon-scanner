{
  "name": "@spotlight/mobile-app",
  "main": "expo-router/entry",
  "version": "0.1.0",
  "scripts": {
    "start": "expo start",
    "visual:design": "bash ../../tools/run_mobile_design_catalog.sh",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "eas:build:ios:development": "pnpm dlx eas-cli build --platform ios --profile development",
    "eas:build:ios:staging": "pnpm dlx eas-cli build --platform ios --profile staging",
    "eas:build:ios:production": "pnpm dlx eas-cli build --platform ios --profile production",
    "eas:submit:ios:staging": "pnpm dlx eas-cli submit --platform ios --profile staging",
    "eas:submit:ios": "pnpm dlx eas-cli submit --platform ios --profile production",
    "mobile:build:ios:staging": "bash ../../tools/run_staging_release_gate.sh build",
    "mobile:release:ios:staging": "bash ../../tools/run_staging_release_gate.sh release",
    "mobile:submit:ios:staging": "bash ../../tools/run_mobile_eas.sh staging submit ios staging",
    "release:ios:staging": "bash ../../tools/run_staging_release_gate.sh release",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:integration": "jest --runInBand __tests__/integration"
  },
  "dependencies": {
    "@react-navigation/native": "^7.1.33",
    "@spotlight/api-client": "workspace:*",
    "@spotlight/design-system": "workspace:*",
    "@supabase/supabase-js": "^2.104.1",
    "@tabler/icons-react-native": "^3.41.1",
    "expo": "~55.0.18",
    "expo-apple-authentication": "~55.0.13",
    "expo-application": "~55.0.14",
    "expo-auth-session": "~55.0.15",
    "expo-blur": "~55.0.14",
    "expo-camera": "~55.0.16",
    "expo-constants": "~55.0.15",
    "expo-dev-client": "~55.0.28",
    "expo-device": "~55.0.15",
    "expo-document-picker": "~55.0.13",
    "expo-file-system": "~55.0.17",
    "expo-font": "~55.0.6",
    "expo-haptics": "~55.0.14",
    "expo-image-manipulator": "~55.0.15",
    "expo-linking": "~55.0.14",
    "expo-localization": "~55.0.13",
    "expo-router": "~55.0.13",
    "expo-secure-store": "~55.0.13",
    "expo-splash-screen": "~55.0.19",
    "expo-status-bar": "~55.0.5",
    "expo-system-ui": "~55.0.16",
    "expo-updates": "~55.0.21",
    "expo-web-browser": "~55.0.14",
    "js-sha256": "^0.11.1",
    "posthog-react-native": "^4.43.13",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "~0.21.0"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.2",
    "eslint": "^9.39.4",
    "eslint-config-expo": "^55.0.0",
    "jest": "^29.7.0",
    "jest-expo": "~55.0.16",
    "typescript": "~5.9.2"
  },
  "private": true
}
