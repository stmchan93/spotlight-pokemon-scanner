# Copy this file to backend/.env.staging.secrets or backend/.env.production.secrets
# for hosted deploys, or pass a different secrets path explicitly to the deploy scripts.

# Optional when your Supabase project uses asymmetric signing with JWKS.
# Required when your bearer tokens are still signed symmetrically (for example HS256).
SUPABASE_JWT_SECRET=your_supabase_jwt_secret
SCRYDEX_API_KEY=your_scrydex_api_key
SCRYDEX_TEAM_ID=your_scrydex_team_id

# Local-dev only. Do not set this in staging/production deploy secrets.
# SPOTLIGHT_AUTH_FALLBACK_USER_ID=local-dev-user

# Optional eBay current-listings integration.
SPOTLIGHT_EBAY_BROWSE_ENABLED=1
EBAY_CLIENT_ID=your_ebay_client_id
EBAY_CLIENT_SECRET=your_ebay_client_secret
EBAY_MARKETPLACE_ID=EBAY_US
