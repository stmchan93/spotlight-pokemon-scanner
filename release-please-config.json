{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "packages": {
    ".": {
      "release-type": "node",
      "include-v-in-tag": true,
      "pull-request-title-pattern": "chore: release ${version}",
      "changelog-sections": [
        {
          "type": "feat",
          "section": "Features"
        },
        {
          "type": "fix",
          "section": "Fixes"
        },
        {
          "type": "perf",
          "section": "Performance"
        },
        {
          "type": "refactor",
          "section": "Maintenance"
        },
        {
          "type": "chore",
          "section": "Maintenance"
        },
        {
          "type": "revert",
          "section": "Reverts"
        },
        {
          "type": "docs",
          "section": "Docs",
          "hidden": true
        },
        {
          "type": "test",
          "section": "Tests",
          "hidden": true
        },
        {
          "type": "ci",
          "section": "CI",
          "hidden": true
        },
        {
          "type": "build",
          "section": "Build",
          "hidden": true
        }
      ],
      "extra-files": [
        {
          "type": "json",
          "path": "apps/spotlight-rn/package.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": "apps/spotlight-rn/app.json",
          "jsonpath": "$.expo.version"
        }
      ]
    }
  }
}
